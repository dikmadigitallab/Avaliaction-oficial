generator client {
  provider = "prisma-client-js"

}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPERVISOR
  ADMINISTRATOR
  ADMIN //do sistema, não do usuário
}

enum QuestionType {
  TEXT
  AVALIAÇÃO
  BOOLEAN
  CHECKBOX
  RADIO
}

model Question {
  id       String  @id @default(uuid())
  title    String
  type     String  @default("TEXT")
  required Boolean @default(false)
  order    Int

  form   Form   @relation(fields: [formId], references: [id], onDelete: Cascade)
  formId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//colocar id de quem criou, ao fazer isso vai ser impossivel criar por fora
model Form {
  id        String     @id @default(uuid()) //id quem crio
  name      String
  anonymous Boolean    @default(true)
  questions Question[]
  respostas Resposta[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}


//supervisor pode criar formularios
model Supervisor {
  id        String   @id @default(uuid())
  name      String
  cpf       String   @unique
  email     String   @unique
  password  String
  role      Role     @default(SUPERVISOR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Administrator {
  id        String   @id @default(uuid())
  name      String
  cpf       String   @unique
  email     String   @unique
  password  String
  role      Role     @default(ADMINISTRATOR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model admin {
  id        String   @id @default(uuid())
  name      String
  cpf       String   @unique
  email     String   @unique
  password  String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model listaCpf {
  id        String   @id @default(uuid())
  cpf       String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Resposta {
  id        String   @id @default(cuid())
  formId    String
  createdAt DateTime @default(now())

  form      Form     @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId])
}

